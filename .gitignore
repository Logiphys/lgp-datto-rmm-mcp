# Dependencies
node_modules/

# Build outputs (sub-packages)
apps/*/dist/
packages/*/dist/
crates/*/target/
build/
.next/
out/

# Root dist/ is committed (standalone npx bundle)
# Do NOT add dist/ here — it is the pre-built MCP server

# Turbo
.turbo/

# Testing
coverage/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
*.swp
*.swo
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Misc
*.tsbuildinfo

# Rust
target/
Cargo.lock

# Claude - Auto-generated files (regenerated by pnpm setup:claude)
# These are copies of files from .ai-docs/ for cross-platform compatibility
.claude/agents/*.md
.claude/commands/*.md

# Keep tracked config files
!.claude/CLAUDE.md
!.claude/README.md
!.claude/settings.json