{
  "name": "lgp-datto-rmm-mcp",
  "version": "0.1.0",
  "description": "Logiphys Datto RMM MCP Server for Claude Desktop",
  "author": "Logiphys Datensysteme GmbH",
  "license": "MIT",
  "homepage": "https://github.com/Logiphys/lgp-datto-rmm-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Logiphys/lgp-datto-rmm-mcp.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lgp-datto-rmm-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "build": "turbo build",
    "build:bundle": "node scripts/bundle.mjs",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "generate:api": "bash tooling/scripts/generate-api-clients.sh",
    "sync:openapi": "bash tooling/scripts/sync-openapi-spec.sh",
    "setup:claude": "bash tooling/scripts/setup-claude-files.sh",
    "validate:ai-docs": "bash tooling/scripts/validate-ai-docs.sh",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}